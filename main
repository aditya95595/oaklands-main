-- Setup Farm Panel Controls
AddSection("Farm", "Auto Farm")
AddToggle("Farm", "Tree Teleport (Click on Tree)", autoTreeTeleport, function(v) autoTreeTeleport = v end)
AddButton("Farm", "🎯 Save Current Position as Sell Point", function()
    if freecamActive then
        targetTreePos = Camera.CFrame.Position
    elseif LocalPlayer.Character and LocalPlayer.Character.PrimaryPart then
        targetTreePos = LocalPlayer.Character.PrimaryPart.Position
    end
    StatusLabel.TextColor3 = Color3.fromRGB(255, 235, 59)
    StatusLabel.Text = "Sell point position registered successfully!"
end)

-- Setup Teleport Panel Controls
AddSection("Teleport", "Teleport Controls")
local tpContainer = Instance.new("Frame")
tpContainer.Size = UDim2.new(1, 0, 0, 0)
tpContainer.BackgroundTransparency = 1
tpContainer.Parent = tpPage
local tpList = Instance.new("UIListLayout") tpList.Padding = UDim.new(0,5) tpList.Parent = tpContainer

local function RenderTeleportList()
    for _, child in pairs(tpContainer:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, loc in ipairs(savedTeleports) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 35)
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        btn.Text = "🚀 " .. loc.Name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 14
        btn.Font = Enum.Font.SourceSans
        btn.Parent = tpContainer
        local BC = Instance.new("UICorner") BC.CornerRadius = UDim.new(0,4) BC.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(loc.Position + Vector3.new(0, 5, 0)) end
        end)
    end
    tpContainer.Size = UDim2.new(1, 0, 0, tpList.AbsoluteContentSize.Y)
end

AddButton("Teleport", "➕ Save Current Location", function()
    local pos = freecamActive and Camera.CFrame.Position or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position)
    if pos then
        table.insert(savedTeleports, {Name = "📍 Point " .. (#savedTeleports + 1), Position = pos})
        RenderTeleportList()
    end
end)

RenderTeleportList()

-- Setup Settings Panel Controls
AddSection("Settings", "Settings")
AddToggle("Settings", "F Key Click Teleport", clickTeleportPlayer, function(v) clickTeleportPlayer = v end)
AddToggle("Settings", "Freecam (WASD + QE)", freecamActive, function(v) ToggleFreecam() end)

-- ==================== AUTH UNLOCK ACTION LOGIC ====================
SubmitBtn.MouseButton1Click:Connect(function()
    local enteredKey = KeyBox.Text
    -- Accept "test" or empty field bypassed testing parameters
    if enteredKey == "test" or enteredKey ~= "" then
        StatusLabel.TextColor3 = Color3.fromRGB(76, 175, 80)
        StatusLabel.Text = "Access granted! Accessing system dashboard..."
        task.wait(1)
        
        -- Transition Page UI States
        KeyPage.Visible = false
        Sidebar.Visible = true
        ContentArea.Visible = true
        tabs["Farm"].page.Visible = true
        tabs["Farm"].button.BackgroundColor3 = Color3.fromRGB(46, 125, 50)
        StatusLabel.Text = ""
    else
        StatusLabel.TextColor3 = Color3.fromRGB(244, 67, 54)
        StatusLabel.Text = "Authentication Key invalid or expired."
    end
end)

-- ==================== GAME INPUT ENGINE HOOKS ====================
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F and clickTeleportPlayer then
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local mouse = LocalPlayer:GetMouse()
            if mouse and mouse.Hit then
                hrp.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
            end
        end
    end
    if input.UserInputType == Enum.UserInputType.MouseButton1 and autoTreeTeleport then
        local finalPos = targetTreePos
        if not finalPos then
            for _, loc in pairs(savedTeleports) do
                if loc.Name:find("Sell") or loc.Name:find("Black") then
                    finalPos = loc.Position
                    break
                end
            end
        end
        if finalPos then
            local mouse = LocalPlayer:GetMouse()
            if mouse.Target then
                local model = mouse.Target:FindFirstAncestorOfClass("Model") or mouse.Target.Parent
                if model then
                    local part = model.PrimaryPart or model:FindFirstChild("Trunk") or model:FindFirstChild("Wood") or model:FindFirstChild("Log") or mouse.Target
                    TeleportTree(part, finalPos)
                end
            end
        end
    end
end)
