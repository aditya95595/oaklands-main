-- ==================== GAME INPUT ENGINE HOOKS ====================
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    -- Original UI F-Key Client Teleportation 
    if input.KeyCode == Enum.KeyCode.F and clickTeleportPlayer then
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local mouse = LocalPlayer:GetMouse()
            if mouse and mouse.Hit then
                hrp.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
            end
        end
    end
    
    -- Integrated Plot Utility Logic Hooks
    if currentPlot and currentFloor then
        if input.KeyCode == getgenv().ItemTeleportKeybind then
            local part = LocalPlayer:GetMouse().Target
            if part and not part.Anchored then
                local model = part:FindFirstAncestorWhichIsA("Model")
                if model and tostring(model.Parent) == "LooseItems" then
                    model.ModelStreamingMode = Enum.ModelStreamingMode.Persistent
                    local root = model:FindFirstChildWhichIsA("BasePart") or model.PrimaryPart

                    for i = 0, 8, 1 do 
                        task.wait()
                        model:PivotTo(currentFloor.CFrame + Vector3.new(0,20,0))
                        local vel = Vector3.new(math.random(-8,8), math.random(3,12), math.random(-8,8))
                        if root then root.AssemblyLinearVelocity = vel end
                    end

                    LocalPlayer:RequestStreamAroundAsync((currentFloor.CFrame + Vector3.new(0,20,0)).Position, 30)
                    task.wait(0.25)
                    model.ModelStreamingMode = Enum.ModelStreamingMode.Default
                end
            end
        elseif input.KeyCode == getgenv().TeleportKeybind then
            local chr = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if chr then
                oldCFrame = chr.CFrame
                chr.CFrame = currentFloor.CFrame + Vector3.new(0,35,0)
            end
        elseif input.KeyCode == getgenv().TeleportKeybindBack then
            local chr = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if chr and oldCFrame then
                chr.CFrame = oldCFrame
            end
        end
    end
    
    -- Wood Translation Click Hook
    if input.UserInputType == Enum.UserInputType.MouseButton1 and autoTreeTeleport then
        local finalPos = targetTreePos
        
        if not finalPos then
            for _, loc in pairs(savedTeleports) do
                if loc.Name:find("Sell") or loc.Name:find("💰") then
                    finalPos = loc.Position
                    break
                end
            end
        end
        
        if finalPos then
            local mouse = LocalPlayer:GetMouse()
            if mouse.Target then
                local model = mouse.Target:FindFirstAncestorOfClass("Model") or mouse.Target.Parent
                if model then
                    local woodPart = model:FindFirstChild("Trunk") or model:FindFirstChild("Wood") or model:FindFirstChild("Log") or model.PrimaryPart
                    
                    if not woodPart and (model.Name:lower():find("tree") or model.Name:lower():find("wood") or model.Name:lower():find("log")) then
                        woodPart = mouse.Target
                    end
                    
                    if woodPart and woodPart:IsA("BasePart") then
                        local character = LocalPlayer.Character
                        local tool = character and character:FindFirstChildOfClass("Tool")
                        
                        if tool and tool:FindFirstChild("Handle") then
                            firetouchinterest(woodPart, tool.Handle, 0)
                            task.wait(0.03)
                            firetouchinterest(woodPart, tool.Handle, 1)
                        else
                            local limb = character and (character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm") or character:FindFirstChild("HumanoidRootPart"))
                            if limb then
                                firetouchinterest(woodPart, limb, 0)
                                task.wait(0.03)
                                firetouchinterest(woodPart, limb, 1)
                            end
                        end
                        
                        task.wait(0.02)
                        
                        if woodPart.Parent:IsA("Model") then
                            for _, part in pairs(woodPart.Parent:GetChildren()) do
                                if part:IsA("BasePart") then
                                    task.spawn(TeleportTree, part, finalPos)
                                end
                            end
                        else
                            task.spawn(TeleportTree, woodPart, finalPos)
                        end
                    end
                end
            end
        end
    end
end)
